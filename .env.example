DISCORD_TOKEN=your-discord-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_GUILD_ID=
RUNNER_DATABASE_PATH=./var/runner.db
RUNNER_ORIGIN=http://127.0.0.1:3000
ALLOWED_ROOTS=/absolute/project/path,/absolute/shared/path
SESSION_MANAGER_USER_IDS=discord-user-id-1
SESSION_MANAGER_ROLE_IDS=discord-role-id-1,discord-role-id-2
CLAUDE_MODEL=sonnet
CLAUDE_CODE_EXECUTABLE=claude
# Optional: set for direct API-key auth, or leave unset to use local Claude CLI login/subscription state.
ANTHROPIC_API_KEY=
